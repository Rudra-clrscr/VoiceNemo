.env
.env.*
token.json
client_secret*.json
*.pem
*.p12
*.pkcs12

# ─── Python Environment & Cache ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─── Multimedia & Standalone Test Logs ──────────────────────────────
*.wav
*.mp3
*.ogg
step*.py
response.wav

# ─── IDE Configurations ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.pydevproject

# ─── Operating System Files ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
